# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/estim-chat

# JWT secret for token signing (use a strong random string, minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Session secret for express-session (use a strong random string)
SESSION_SECRET=your-super-secret-session-key-change-in-production-min-32-chars

# Optional frontend origin for CORS and Socket.IO
CLIENT_URL=http://localhost:5000

# OAuth configuration (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# APPLE_CALLBACK_URL=http://localhost:5000/api/auth/apple/callback

# Optional upload limits
MAX_FILE_SIZE_MB=20
